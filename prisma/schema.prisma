generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PackageSnapshot {
  id                 String         @id @default(cuid())
  trackingNumber     String         @unique
  currentStatus      PackageStatus
  currentTerminalId  Int?
  updatedAt          DateTime       @updatedAt
  currentContainerId String?
  currentTrailerId   String?
  events             PackageEvent[]
}

model Terminal {
  id           Int               @id @default(autoincrement())
  terminalCode String            @unique
  name         String
  city         String
  province     String
  country      String
  timezone     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  events       TerminalEvent[]
  snapshot     TerminalSnapshot?
}

model TerminalEvent {
  id            String            @id @default(cuid())
  terminalId    Int
  eventType     TerminalEventType
  employeeId    Int?
  correlationId String
  payload       Json?
  createdAt     DateTime          @default(now())
  terminal      Terminal          @relation(fields: [terminalId], references: [id])

  @@index([terminalId, createdAt])
  @@index([correlationId])
}

model TerminalSnapshot {
  id              String         @id @default(cuid())
  terminalId      Int            @unique
  currentStatus   TerminalStatus @default(ACTIVE)
  packageCount    Int            @default(0)
  containerCount  Int            @default(0)
  trailerCount    Int            @default(0)
  truckCount      Int            @default(0)
  activeTripCount Int            @default(0)
  employeeCount   Int            @default(0)
  lastActivityAt  DateTime?
  updatedAt       DateTime       @updatedAt
  terminal        Terminal       @relation(fields: [terminalId], references: [id])
}

model User {
  id             String        @id @default(cuid())
  employeeNumber String        @unique
  email          String        @unique
  firstName      String
  lastName       String
  passwordHash   String?
  tokenVersion   Int           @default(0)
  createdAt      DateTime      @default(now())
  events         UserEvent[]
  snapshot       UserSnapshot?
  roles          UserRole[]
  refreshTokens  RefreshToken[]
}

model UserEvent {
  id            String        @id @default(cuid())
  userId        String
  eventType     UserEventType
  actorUserId   String?
  correlationId String
  payload       Json?
  metadata      Json?
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([correlationId])
}

model UserSnapshot {
  id             String     @id @default(cuid())
  userId         String     @unique
  employeeNumber String
  email          String
  firstName      String
  lastName       String
  currentStatus  UserStatus @default(INACTIVE)
  roleNames      String[]   @default([])
  permissions    String[]   @default([])
  lastLoginAt    DateTime?
  lastActivityAt DateTime?
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([employeeNumber])
  @@index([currentStatus])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model IdentityEvent {
  id            String                @id @default(cuid())
  aggregateId   String
  aggregateType IdentityAggregateType
  eventType     IdentityEventType
  actorUserId   String?
  correlationId String
  payload       Json?
  metadata      Json?
  createdAt     DateTime              @default(now())

  @@index([aggregateType, aggregateId, createdAt])
  @@index([correlationId])
}

model PackageEvent {
  id         String           @id @default(cuid())
  packageId  String
  eventType  PackageEventType
  terminalId Int?
  employeeId Int?
  metadata   Json?
  createdAt  DateTime         @default(now())
  package    PackageSnapshot  @relation(fields: [packageId], references: [id])
}

model ContainerSnapshot {
  id                String           @id @default(cuid())
  containerBarcode  String           @unique
  currentStatus     ContainerStatus
  currentTrailerId  String?
  currentTerminalId Int?
  packageCount      Int              @default(0)
  updatedAt         DateTime         @updatedAt
  events            ContainerEvent[]
}

model ContainerEvent {
  id          String             @id @default(cuid())
  containerId String
  eventType   ContainerEventType
  employeeId  Int?
  metadata    Json?
  createdAt   DateTime           @default(now())
  container   ContainerSnapshot  @relation(fields: [containerId], references: [id])
}

model PackageContainerHistory {
  id          String    @id @default(cuid())
  packageId   String
  containerId String
  loadedAt    DateTime  @default(now())
  unloadedAt  DateTime?
}

model TrailerSnapshot {
  id                String         @id @default(cuid())
  trailerBarcode    String         @unique
  currentStatus     TrailerStatus
  containerCount    Int            @default(0)
  packageCount      Int            @default(0)
  currentTerminalId Int?
  updatedAt         DateTime       @updatedAt
  events            TrailerEvent[]
}

model TrailerEvent {
  id        String           @id @default(cuid())
  trailerId String
  eventType TrailerEventType
  createdAt DateTime         @default(now())
  trailer   TrailerSnapshot  @relation(fields: [trailerId], references: [id])
}

model ContainerTrailerHistory {
  id          String    @id @default(cuid())
  containerId String
  trailerId   String
  loadedAt    DateTime  @default(now())
  unloadedAt  DateTime?
}

model PackageTrailerHistory {
  id         String    @id @default(cuid())
  packageId  String
  trailerId  String
  loadedAt   DateTime  @default(now())
  unloadedAt DateTime?
}

enum PackageStatus {
  RECEIVED
  SORTED
  IN_CONTAINER
  IN_TRAILER
  DEPARTED
  ARRIVED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PackageEventType {
  PACKAGE_RECEIVED
  PACKAGE_SORTED
  PACKAGE_LOADED_TO_CONTAINER
  PACKAGE_UNLOADED_FROM_CONTAINER
  PACKAGE_LOADED_TO_TRAILER
  PACKAGE_UNLOADED_FROM_TRAILER
  PACKAGE_DEPARTED
  PACKAGE_ARRIVED
  PACKAGE_OUT_FOR_DELIVERY
  PACKAGE_DELIVERED
}

enum ContainerStatus {
  OPEN
  CLOSED
  IN_TRANSIT
  ARRIVED
}

enum ContainerEventType {
  CONTAINER_CREATED
  CONTAINER_CLOSED
  CONTAINER_DEPARTED
  CONTAINER_ARRIVED
}

enum TrailerStatus {
  OPEN
  CLOSED
  IN_TRANSIT
  ARRIVED
}

enum TrailerEventType {
  TRAILER_CREATED
  TRAILER_CLOSED
  TRAILER_DEPARTED
  TRAILER_ARRIVED

  CONTAINER_LOADED_TO_TRAILER
  CONTAINER_UNLOADED_FROM_TRAILER
}

enum TerminalStatus {
  ACTIVE
  OPERATIONAL
  MAINTENANCE
  CLOSED
}

enum TerminalEventType {
  TERMINAL_CREATED
  TERMINAL_UPDATED
  PACKAGE_RECEIVED
  PACKAGE_TRANSFERRED
  CONTAINER_RECEIVED
  CONTAINER_TRANSFERRED
  TRAILER_ARRIVED
  TRAILER_DEPARTED
}

enum TerminalAssetType {
  PACKAGE
  CONTAINER
  TRAILER
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum UserEventType {
  USER_CREATED
  ROLE_ASSIGNED
  ROLE_REMOVED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_AUTHENTICATED
  REFRESH_TOKEN_ROTATED
  USER_LOGGED_OUT
  PASSWORD_CHANGED
}

enum IdentityAggregateType {
  ROLE
  PERMISSION
}

enum IdentityEventType {
  ROLE_CREATED
  PERMISSION_CREATED
  PERMISSION_ASSIGNED
}
