{
  "extends": "../tsconfig.json",

  "compilerOptions": {
    // Explicit root directory for tests
    "rootDir": "../",

    "ignoreDeprecations": "5.0",

    // Required for Jest transpilation
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,

    // Allow Jest globals/types
    "types": ["jest", "node"]
  },

  "include": [
    "../src/**/*",
    "./**/*"
  ]
}
