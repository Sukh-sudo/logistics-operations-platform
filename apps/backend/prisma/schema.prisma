generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PackageSnapshot {
  id                 String            @id @default(cuid())
  trackingNumber     String            @unique
  packageType        PackageType
  currentStatus      PackageStatus
  currentTerminalId  Int?
  updatedAt          DateTime          @updatedAt
  currentContainerId String?
  currentTrailerId   String?
  events             PackageEvent[]
  shipmentPackages   ShipmentPackage[]
}

model Terminal {
  id                   Int               @id @default(autoincrement())
  terminalCode         String            @unique
  name                 String
  city                 String
  province             String
  country              String
  timezone             String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  events               TerminalEvent[]
  snapshot             TerminalSnapshot?
  originatingRoutes    Route[]           @relation("RouteOriginTerminal")
  destinationRoutes    Route[]           @relation("RouteDestinationTerminal")
  routeStops           RouteStop[]
  tripStops            TripStop[]
  originatingShipments Shipment[]        @relation("ShipmentOriginTerminal")
  destinationShipments Shipment[]        @relation("ShipmentDestinationTerminal")
  primaryUsers         User[]
}

model Route {
  id                    String         @id @default(cuid())
  routeNumber           String         @unique
  name                  String
  originTerminalId      Int
  destinationTerminalId Int
  status                RouteStatus    @default(CREATED)
  estimatedDistance     Int            @default(0)
  estimatedDuration     Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  originTerminal        Terminal       @relation("RouteOriginTerminal", fields: [originTerminalId], references: [id])
  destinationTerminal   Terminal       @relation("RouteDestinationTerminal", fields: [destinationTerminalId], references: [id])
  stops                 RouteStop[]
  events                RouteEvent[]
  snapshot              RouteSnapshot?
  trips                 Trip[]

  @@index([originTerminalId])
  @@index([destinationTerminalId])
  @@index([status])
}

model Trip {
  id                    String        @id @default(cuid())
  tripNumber            String        @unique
  routeId               String
  equipmentAssignmentId String?
  status                TripStatus    @default(CREATED)
  plannedDeparture      DateTime
  actualDeparture       DateTime?
  plannedArrival        DateTime
  actualArrival         DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  route                 Route         @relation(fields: [routeId], references: [id])
  stops                 TripStop[]
  events                TripEvent[]
  snapshot              TripSnapshot?

  @@index([routeId])
  @@index([status])
}

model TripStop {
  id               String         @id @default(cuid())
  tripId           String
  terminalId       Int
  sequence         Int
  plannedArrival   DateTime
  actualArrival    DateTime?
  plannedDeparture DateTime
  actualDeparture  DateTime?
  status           TripStopStatus @default(PENDING)
  delayMinutes     Int            @default(0)
  notes            String?
  trip             Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  terminal         Terminal       @relation(fields: [terminalId], references: [id])

  @@unique([tripId, sequence])
  @@index([terminalId])
}

model TripEvent {
  id            String        @id @default(cuid())
  tripId        String
  eventType     TripEventType
  correlationId String
  payload       Json?
  createdAt     DateTime      @default(now())
  trip          Trip          @relation(fields: [tripId], references: [id])

  @@index([tripId, createdAt])
  @@index([correlationId])
}

model TripSnapshot {
  id                String     @id @default(cuid())
  tripId            String     @unique
  currentStatus     TripStatus @default(CREATED)
  currentStopId     String?
  nextStopId        String?
  currentTerminalId Int?
  completedStops    Int        @default(0)
  totalStops        Int        @default(0)
  progressPercent   Int        @default(0)
  delayMinutes      Int        @default(0)
  lastActivityAt    DateTime?
  updatedAt         DateTime   @updatedAt
  trip              Trip       @relation(fields: [tripId], references: [id])

  @@index([currentStatus])
}

model Shipment {
  id                    String            @id @default(cuid())
  shipmentNumber        String            @unique
  referenceNumber       String?
  status                ShipmentStatus    @default(CREATED)
  originTerminalId      Int
  destinationTerminalId Int
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  originTerminal        Terminal          @relation("ShipmentOriginTerminal", fields: [originTerminalId], references: [id])
  destinationTerminal   Terminal          @relation("ShipmentDestinationTerminal", fields: [destinationTerminalId], references: [id])
  packages              ShipmentPackage[]
  events                ShipmentEvent[]
  snapshot              ShipmentSnapshot?

  @@index([originTerminalId])
  @@index([destinationTerminalId])
  @@index([status])
}

model ShipmentPackage {
  shipmentId String
  packageId  String
  assignedAt DateTime        @default(now())
  shipment   Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  package    PackageSnapshot @relation(fields: [packageId], references: [id])

  @@id([shipmentId, packageId])
  @@unique([packageId])
}

model ShipmentEvent {
  id            String            @id @default(cuid())
  shipmentId    String
  eventType     ShipmentEventType
  correlationId String
  payload       Json?
  createdAt     DateTime          @default(now())
  shipment      Shipment          @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId, createdAt])
  @@index([correlationId])
}

model ShipmentSnapshot {
  id                String         @id @default(cuid())
  shipmentId        String         @unique
  currentStatus     ShipmentStatus @default(CREATED)
  packageCount      Int            @default(0)
  deliveredPackages Int            @default(0)
  remainingPackages Int            @default(0)
  progressPercent   Int            @default(0)
  lastActivityAt    DateTime?
  updatedAt         DateTime       @updatedAt
  shipment          Shipment       @relation(fields: [shipmentId], references: [id])

  @@index([currentStatus])
}

model RouteStop {
  id                       String   @id @default(cuid())
  routeId                  String
  terminalId               Int
  sequence                 Int
  estimatedArrivalOffset   Int
  estimatedDepartureOffset Int
  route                    Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  terminal                 Terminal @relation(fields: [terminalId], references: [id])

  @@unique([routeId, sequence])
  @@unique([routeId, terminalId])
  @@index([terminalId])
}

model RouteEvent {
  id            String         @id @default(cuid())
  routeId       String
  eventType     RouteEventType
  employeeId    Int?
  correlationId String
  payload       Json?
  createdAt     DateTime       @default(now())
  route         Route          @relation(fields: [routeId], references: [id])

  @@index([routeId, createdAt])
  @@index([correlationId])
}

model RouteSnapshot {
  id                String      @id @default(cuid())
  routeId           String      @unique
  currentStatus     RouteStatus @default(CREATED)
  stopCount         Int         @default(0)
  currentStops      Json
  estimatedDistance Int         @default(0)
  estimatedDuration Int         @default(0)
  lastActivityAt    DateTime?
  updatedAt         DateTime    @updatedAt
  route             Route       @relation(fields: [routeId], references: [id])

  @@index([currentStatus])
}

model TerminalEvent {
  id            String            @id @default(cuid())
  terminalId    Int
  eventType     TerminalEventType
  employeeId    Int?
  correlationId String
  payload       Json?
  createdAt     DateTime          @default(now())
  terminal      Terminal          @relation(fields: [terminalId], references: [id])

  @@index([terminalId, createdAt])
  @@index([correlationId])
}

model TerminalSnapshot {
  id              String         @id @default(cuid())
  terminalId      Int            @unique
  currentStatus   TerminalStatus @default(ACTIVE)
  packageCount    Int            @default(0)
  containerCount  Int            @default(0)
  trailerCount    Int            @default(0)
  truckCount      Int            @default(0)
  activeTripCount Int            @default(0)
  employeeCount   Int            @default(0)
  lastActivityAt  DateTime?
  updatedAt       DateTime       @updatedAt
  terminal        Terminal       @relation(fields: [terminalId], references: [id])
}

model User {
  id                String         @id @default(cuid())
  employeeNumber    String         @unique
  email             String         @unique
  firstName         String
  lastName          String
  passwordHash      String?
  tokenVersion      Int            @default(0)
  createdAt         DateTime       @default(now())
  events            UserEvent[]
  snapshot          UserSnapshot?
  roles             UserRole[]
  refreshTokens     RefreshToken[]
  primaryTerminalId Int?
  primaryTerminal   Terminal?      @relation(fields: [primaryTerminalId], references: [id])

  @@index([primaryTerminalId])
}

model UserEvent {
  id            String        @id @default(cuid())
  userId        String
  eventType     UserEventType
  actorUserId   String?
  correlationId String
  payload       Json?
  metadata      Json?
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([correlationId])
}

model UserSnapshot {
  id                String     @id @default(cuid())
  userId            String     @unique
  employeeNumber    String
  email             String
  firstName         String
  lastName          String
  currentStatus     UserStatus @default(INACTIVE)
  currentTerminalId Int?
  roleNames         String[]   @default([])
  permissions       String[]   @default([])
  lastLoginAt       DateTime?
  lastActivityAt    DateTime?
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([employeeNumber])
  @@index([currentStatus])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model IdentityEvent {
  id            String                @id @default(cuid())
  aggregateId   String
  aggregateType IdentityAggregateType
  eventType     IdentityEventType
  actorUserId   String?
  correlationId String
  payload       Json?
  metadata      Json?
  createdAt     DateTime              @default(now())

  @@index([aggregateType, aggregateId, createdAt])
  @@index([correlationId])
}

model PackageEvent {
  id         String           @id @default(cuid())
  packageId  String
  eventType  PackageEventType
  terminalId Int?
  employeeId Int?
  metadata   Json?
  createdAt  DateTime         @default(now())
  package    PackageSnapshot  @relation(fields: [packageId], references: [id])
}

model ContainerSnapshot {
  id                String           @id @default(cuid())
  containerBarcode  String           @unique
  packageType       PackageType
  currentStatus     ContainerStatus
  currentTrailerId  String?
  currentTerminalId Int?
  packageCount      Int              @default(0)
  updatedAt         DateTime         @updatedAt
  events            ContainerEvent[]
}

model ContainerEvent {
  id          String             @id @default(cuid())
  containerId String
  eventType   ContainerEventType
  employeeId  Int?
  metadata    Json?
  createdAt   DateTime           @default(now())
  container   ContainerSnapshot  @relation(fields: [containerId], references: [id])
}

model PackageContainerHistory {
  id          String    @id @default(cuid())
  packageId   String
  containerId String
  loadedAt    DateTime  @default(now())
  unloadedAt  DateTime?
}

model TrailerSnapshot {
  id                String         @id @default(cuid())
  trailerBarcode    String         @unique
  currentStatus     TrailerStatus
  containerCount    Int            @default(0)
  packageCount      Int            @default(0)
  currentTerminalId Int?
  updatedAt         DateTime       @updatedAt
  events            TrailerEvent[]
}

model TrailerEvent {
  id        String           @id @default(cuid())
  trailerId String
  eventType TrailerEventType
  createdAt DateTime         @default(now())
  trailer   TrailerSnapshot  @relation(fields: [trailerId], references: [id])
}

model ContainerTrailerHistory {
  id          String    @id @default(cuid())
  containerId String
  trailerId   String
  loadedAt    DateTime  @default(now())
  unloadedAt  DateTime?
}

model PackageTrailerHistory {
  id         String    @id @default(cuid())
  packageId  String
  trailerId  String
  loadedAt   DateTime  @default(now())
  unloadedAt DateTime?
}

enum PackageStatus {
  RECEIVED
  SORTED
  IN_CONTAINER
  IN_TRAILER
  DEPARTED
  ARRIVED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PackageType {
  MAIL
  CONVEYABLE
  NON_CONVEYABLE
  DANGEROUS_GOODS
}

enum PackageEventType {
  PACKAGE_RECEIVED
  PACKAGE_SORTED
  PACKAGE_LOADED_TO_CONTAINER
  PACKAGE_UNLOADED_FROM_CONTAINER
  PACKAGE_LOADED_TO_TRAILER
  PACKAGE_UNLOADED_FROM_TRAILER
  PACKAGE_DEPARTED
  PACKAGE_ARRIVED
  PACKAGE_OUT_FOR_DELIVERY
  PACKAGE_DELIVERED
}

enum ContainerStatus {
  OPEN
  CLOSED
  IN_TRANSIT
  ARRIVED
}

enum ContainerEventType {
  CONTAINER_CREATED
  CONTAINER_CLOSED
  CONTAINER_DEPARTED
  CONTAINER_ARRIVED
}

enum TrailerStatus {
  OPEN
  CLOSED
  IN_TRANSIT
  ARRIVED
}

enum TrailerEventType {
  TRAILER_CREATED
  TRAILER_CLOSED
  TRAILER_DEPARTED
  TRAILER_ARRIVED

  CONTAINER_LOADED_TO_TRAILER
  CONTAINER_UNLOADED_FROM_TRAILER
}

enum TerminalStatus {
  ACTIVE
  OPERATIONAL
  MAINTENANCE
  CLOSED
}

enum TerminalEventType {
  TERMINAL_CREATED
  TERMINAL_UPDATED
  PACKAGE_RECEIVED
  PACKAGE_TRANSFERRED
  CONTAINER_RECEIVED
  CONTAINER_TRANSFERRED
  TRAILER_ARRIVED
  TRAILER_DEPARTED
}

enum TerminalAssetType {
  PACKAGE
  CONTAINER
  TRAILER
}

enum RouteStatus {
  CREATED
  ACTIVE
  RETIRED
}

enum RouteEventType {
  ROUTE_CREATED
  ROUTE_UPDATED
  STOP_ADDED
  STOP_REMOVED
  ROUTE_ACTIVATED
  ROUTE_RETIRED
}

enum TripStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripStopStatus {
  PENDING
  ARRIVED
  DEPARTED
}

enum TripEventType {
  TRIP_CREATED
  TRIP_UPDATED
  TRIP_STARTED
  STOP_ARRIVED
  STOP_DEPARTED
  STOP_DELAYED
  TRIP_COMPLETED
  TRIP_CANCELLED
}

enum ShipmentStatus {
  CREATED
  PACKAGES_ASSIGNED
  IN_TRANSIT
  PARTIALLY_DELIVERED
  COMPLETED
  CANCELLED
}

enum ShipmentEventType {
  SHIPMENT_CREATED
  SHIPMENT_UPDATED
  PACKAGE_ASSIGNED
  PACKAGE_REMOVED
  SHIPMENT_IN_TRANSIT
  SHIPMENT_COMPLETED
  SHIPMENT_CANCELLED
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum UserEventType {
  USER_CREATED
  ROLE_ASSIGNED
  ROLE_REMOVED
  USER_ACTIVATED
  USER_DEACTIVATED
  USER_AUTHENTICATED
  REFRESH_TOKEN_ROTATED
  USER_LOGGED_OUT
  PASSWORD_CHANGED
  TERMINAL_ASSIGNED
}

enum IdentityAggregateType {
  ROLE
  PERMISSION
}

enum IdentityEventType {
  ROLE_CREATED
  PERMISSION_CREATED
  PERMISSION_ASSIGNED
}
